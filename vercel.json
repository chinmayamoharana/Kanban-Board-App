{
  "installCommand": "npm --prefix kanban-frontend install",
  "buildCommand": "npm --prefix kanban-frontend run build",
  "outputDirectory": "kanban-frontend/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://kanban-board-app-9ip9.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
